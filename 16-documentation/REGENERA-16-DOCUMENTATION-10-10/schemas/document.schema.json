{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:regenera:documentation:document:1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "owner",
    "reviewers",
    "status",
    "version",
    "classification",
    "last_reviewed",
    "next_review_due",
    "source_of_truth"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Z0-9][A-Z0-9.-]{2,63}$"
    },
    "title": {
      "type": "string",
      "minLength": 5
    },
    "owner": {
      "type": "string",
      "minLength": 2
    },
    "reviewers": {
      "type": "string",
      "minLength": 2
    },
    "status": {
      "enum": [
        "DRAFT",
        "ACTIVE",
        "SUPERSEDED",
        "RETIRED",
        "EXTERNAL_PENDING"
      ]
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "classification": {
      "enum": [
        "PUBLIC",
        "INTERNAL",
        "CONFIDENTIAL",
        "RESTRICTED"
      ]
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "next_review_due": {
      "type": "string",
      "format": "date"
    },
    "source_of_truth": {
      "type": "string",
      "minLength": 3
    }
  }
}
