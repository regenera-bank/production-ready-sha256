{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:regenera:quality:release-gate:1",
  "type": "object",
  "required": ["artifact_digest", "decision", "checks"],
  "properties": {
    "artifact_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "decision": {"enum": ["APPROVED", "BLOCKED"]},
    "checks": {"type": "array", "minItems": 1}
  },
  "additionalProperties": true
}
