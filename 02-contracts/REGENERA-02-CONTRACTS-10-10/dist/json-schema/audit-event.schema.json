{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:regenera:schema:audit-event:1",
  "title": "AuditEvent",
  "type": "object",
  "required": [
    "eventId",
    "eventType",
    "occurredAt",
    "actor",
    "subject",
    "correlationId",
    "evidenceHash"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "eventType": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]{2,79}$"
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "type": "object",
      "required": [
        "type",
        "id"
      ],
      "properties": {
        "type": {
          "enum": [
            "USER",
            "SERVICE",
            "OPERATOR",
            "SYSTEM"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      },
      "additionalProperties": false
    },
    "subject": {
      "type": "object",
      "required": [
        "type",
        "id"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      },
      "additionalProperties": false
    },
    "correlationId": {
      "type": "string",
      "format": "uuid"
    },
    "causationId": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    },
    "evidenceHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "detail": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
