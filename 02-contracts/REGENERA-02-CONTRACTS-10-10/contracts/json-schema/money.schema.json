{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:regenera:schema:money:1",
  "title": "Money",
  "type": "object",
  "required": [
    "currency",
    "amountCents"
  ],
  "properties": {
    "currency": {
      "type": "string",
      "const": "BRL"
    },
    "amountCents": {
      "type": "string",
      "pattern": "^-?(0|[1-9][0-9]{0,18})$"
    }
  },
  "additionalProperties": false
}
