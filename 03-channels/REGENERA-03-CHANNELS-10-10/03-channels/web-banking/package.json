{
  "name": "@regenera/bank-frontend-enterprise",
  "private": true,
  "version": "6.0.0",
  "type": "module",
  "description": "Regulated Core Banking Super-App - Contract First & Observable",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "generate:api": "orval --config ./orval.config.ts",
    "orval": "orval --config ./orval.config.ts",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings 0",
    "lint:deps": "depcruise src --config .dependency-cruiser.js",
    "test": "vitest run --passWithNoTests",
    "test:cov": "vitest run --coverage --passWithNoTests",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@opentelemetry/api": "^1.8.0",
    "@sentry/react": "^7.106.0",
    "@sentry/tracing": "^7.106.0",
    "@tanstack/react-query": "^5.28.4",
    "@unleash/proxy-client-react": "^6.0.0",
    "clsx": "^2.1.0",
    "firebase": "^12.14.0",
    "framer-motion": "^11.0.8",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-error-boundary": "^4.0.13",
    "react-hook-form": "^7.51.0",
    "react-router-dom": "^6.22.3",
    "recharts": "^2.12.2",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^2.2.1",
    "wretch": "^2.8.0",
    "zod": "^3.22.4",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.1",
    "@tanstack/eslint-plugin-query": "^5.28.4",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react-swc": "^3.6.0",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.4.18",
    "dependency-cruiser": "^16.2.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "husky": "^9.0.11",
    "jsdom": "^24.0.0",
    "lint-staged": "^15.2.2",
    "msw": "^2.2.3",
    "orval": "^8.18.0",
    "postcss": "^8.4.35",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.4.2",
    "vite": "^7.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
